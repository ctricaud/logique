  {"id":116,"categorie":"Horaires et durées","niveau":2,"question":"Une course commence à 10h30. Les premiers coureurs arrivent 1h48 plus tard. À quelle heure ?","options":["12h08","12h18","12h28"],"reponse":"12h18","explication":"10h30 + 1h48 = 10h + 1h + 30 + 48 min = 11h + 78 min = 12h18."},
  {"id":117,"categorie":"Horaires et durées","niveau":2,"question":"Un spectacle se joue à 20h15 et 22h30. Quelle est la durée entre les deux représentations ?","options":["2h00","2h15","2h30"],"reponse":"2h15","explication":"De 20h15 à 22h30 = 2 heures 15 minutes."},
  {"id":118,"categorie":"Problèmes","niveau":2,"question":"Sara a lu 3/4 d'un livre de 240 pages. Combien de pages a-t-elle lues ?","options":["160","180","200"],"reponse":"180","explication":"3/4 de 240 = 240 × 3 ÷ 4 = 180 pages."},
