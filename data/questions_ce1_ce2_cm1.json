  {"id":126,"categorie":"Horaires et durées","niveau":3,"question":"Un train roule à 180 km/h. Combien de temps met-il pour parcourir 270 km ?","options":["1h","1h30","2h"],"reponse":"1h30","explication":"270 ÷ 180 = 1,5 h = 1 heure 30 minutes."},
