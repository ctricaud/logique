  {"id":162,"categorie":"Suites numériques","niveau":2,"question":"Quelle est la suite : 1/2, 2/3, 3/4, 4/5, … ?","options":["4/6","5/6","6/7"],"reponse":"5/6","explication":"Numérateur et dénominateur augmentent de 1. Après 4/5 vient 5/6."},
