  {"id":98,"categorie":"Mesures","niveau":3,"question":"Quelle est la surface d'un cercle de rayon 7 cm ? (π ≈ 3,14)","options":["43,96 cm²","153,86 cm²","175,84 cm²"],"reponse":"153,86 cm²","explication":"Surface = π × r² = 3,14 × 49 = 153,86 cm²."},
  {"id":99,"categorie":"Mesures","niveau":3,"question":"Un cylindre a un rayon de 3 cm et une hauteur de 10 cm. Quel est son volume ? (π ≈ 3,14)","options":["94,2 cm³","282,6 cm³","565,2 cm³"],"reponse":"282,6 cm³","explication":"Volume = π × r² × h = 3,14 × 9 × 10 = 282,6 cm³."},
  {"id":100,"categorie":"Fractions","niveau":3,"question":"Combien font 3/4 × 8/9 ?","options":["11/13","2/3","24/36"],"reponse":"2/3","explication":"3/4 × 8/9 = 24/36 = 2/3 (simplifié par 12)."},
  {"id":101,"categorie":"Calcul mental","niveau":1,"question":"Combien font 4 + 4 + 4 + 4 ?","options":["12","16","20"],"reponse":"16","explication":"4 fois 4 = 4 × 4 = 16."},
