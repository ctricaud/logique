  {"id":178,"categorie":"Suites numériques","niveau":1,"question":"Quelle est la suite : 4, 8, 16, 32, … ?","options":["40","48","64"],"reponse":"64","explication":"On multiplie par 2. 32 × 2 = 64."},
  {"id":179,"categorie":"Horaires et durées","niveau":1,"question":"Une séance de cinéma dure 2h30. Elle commence à 15h00. À quelle heure finit-elle ?","options":["16h30","17h30","18h00"],"reponse":"17h30","explication":"15h00 + 2h30 = 17h30."},
  {"id":180,"categorie":"Problèmes","niveau":1,"question":"Un rectangle mesure 8 cm de long et 3 cm de large. Quelle est sa surface ?","options":["11 cm²","22 cm²","24 cm²"],"reponse":"24 cm²","explication":"Surface = 8 × 3 = 24 cm²."},
  {"id":181,"categorie":"Calcul mental","niveau":2,"question":"Combien font 12,5 × 8 ?","options":["80","90","100"],"reponse":"100","explication":"12,5 × 8 = 100. Car 12,5 = 100/8."},
  {"id":182,"categorie":"Suites numériques","niveau":2,"question":"Quelle est la suite : 0,5 ; 1,5 ; 4,5 ; 13,5 ; … ?","options":["27","40,5","54"],"reponse":"40,5","explication":"On multiplie par 3 à chaque fois. 13,5 × 3 = 40,5."},
  {"id":183,"categorie":"Horaires et durées","niveau":2,"question":"Il est 14h22. Dans 3h48, quelle heure sera-t-il ?","options":["17h10","18h00","18h10"],"reponse":"18h10","explication":"14h22 + 3h48 = 14h + 3h + 22 + 48 min = 17h + 70 min = 18h10."},
  {"id":184,"categorie":"Problèmes","niveau":2,"question":"30% d'une classe est absent. Il y a 21 élèves présents. Combien d'élèves compte la classe ?","options":["28","30","35"],"reponse":"30","explication":"Si 30% sont absents, 70% sont présents. 21 = 70% × total. Total = 21 ÷ 0,7 = 30."},
  {"id":185,"categorie":"Fractions","niveau":2,"question":"Quel est le résultat de 1/2 × 3/4 × 2/3 ?","options":["1/4","1/3","6/24"],"reponse":"1/4","explication":"1/2 × 3/4 × 2/3 = 6/24 = 1/4."},
  {"id":186,"categorie":"Calcul mental","niveau":3,"question":"Combien font 36 × 25 ?","options":["750","800","900"],"reponse":"900","explication":"36 × 25 = 36 × 100/4 = 3600/4 = 900."},
  {"id":187,"categorie":"Suites numériques","niveau":3,"question":"Quelle est la suite : 2, 5, 14, 41, … ?","options":["100","122","124"],"reponse":"122","explication":"On multiplie par 3 et on soustrait 1 : 41 × 3 – 1 = 122."},
  {"id":188,"categorie":"Ordre et classement","niveau":3,"question":"Range ces expressions dans l'ordre croissant : 5!/4!, 3!-1, 2²+1, (1+1)³.","options":["2²+1, 3!-1, 5!/4!, (1+1)³","3!-1, 2²+1, 5!/4!, (1+1)³","2²+1, 5!/4!, 3!-1, (1+1)³"],"reponse":"2²+1, 3!-1, 5!/4!, (1+1)³","explication":"5!/4!=5, 3!–1=5, 2²+1=5, (1+1)³=8. Ils valent tous 5 sauf le dernier."},
  {"id":189,"categorie":"Horaires et durées","niveau":3,"question":"Un train roule à 250 km/h. Combien de mètres parcourt-il en 1 seconde ?","options":["54 m","69 m","250 m"],"reponse":"69 m","explication":"250 km/h = 250 000 m / 3 600 s ≈ 69,4 m/s."},
  {"id":190,"categorie":"Problèmes","niveau":3,"question":"Un escalier compte 18 marches. On monte 3 marches, on redescend 1, et on recommence. Après combien de cycles est-on en haut ?","options":["7","9","10"],"reponse":"9","explication":"Chaque cycle (monter 3, descendre 1) avance de 2 marches nettes. 18 ÷ 2 = 9 cycles."},
  {"id":191,"categorie":"Mesures","niveau":3,"question":"Convertis 3,6 km/min en km/h.","options":["60 km/h","180 km/h","216 km/h"],"reponse":"216 km/h","explication":"3,6 km/min × 60 min/h = 216 km/h."},
  {"id":192,"categorie":"Fractions","niveau":3,"question":"Simplifie 84/126.","options":["2/3","7/9","4/6"],"reponse":"2/3","explication":"PGCD(84,126)=42. 84÷42=2, 126÷42=3. Donc 84/126 = 2/3."},
  {"id":193,"categorie":"Calcul mental","niveau":1,"question":"Combien font 50 + 50 + 50 ?","options":["100","150","200"],"reponse":"150","explication":"50 × 3 = 150."},
  {"id":194,"categorie":"Calcul mental","niveau":2,"question":"Combien font 999 + 1 ?","options":["999","1000","1001"],"reponse":"1000","explication":"999 + 1 = 1000."},
  {"id":195,"categorie":"Problèmes","niveau":1,"question":"Dans une boîte, il y a 3 rangées de 5 chocolats. Combien y a-t-il de chocolats en tout ?","options":["8","12","15"],"reponse":"15","explication":"3 rangées × 5 chocolats = 15 chocolats."},
  {"id":196,"categorie":"Mesures","niveau":1,"question":"Tu marches 500 m. Combien de km as-tu parcouru ?","options":["0,05 km","0,5 km","5 km"],"reponse":"0,5 km","explication":"500 m = 500 ÷ 1000 = 0,5 km."},
  {"id":197,"categorie":"Ordre et classement","niveau":1,"question":"Quel est le plus petit nombre pair supérieur à 7 ?","options":["6","8","9"],"reponse":"8","explication":"8 est pair (divisible par 2) et est bien supérieur à 7."},
  {"id":198,"categorie":"Horaires et durées","niveau":2,"question":"Une recette demande 45 minutes de préparation et 1h15 de cuisson. Combien de temps au total ?","options":["1h45","2h00","2h15"],"reponse":"2h00","explication":"45 min + 1h15 = 1h + (45+15) min = 1h + 60 min = 2h00."},
  {"id":199,"categorie":"Problèmes","niveau":3,"question":"Si la moitié d'un nombre augmenté de 3 est égal à 10, quel est ce nombre ?","options":["10","14","20"],"reponse":"14","explication":"n/2 + 3 = 10 → n/2 = 7 → n = 14."},
  {"id":200,"categorie":"Fractions","niveau":3,"question":"Combien font 5/6 × 12/25 ?","options":["2/5","60/150","1/3"],"reponse":"2/5","explication":"5/6 × 12/25 = 60/150 = 2/5 (simplifié par 30)."}
