  {"id":164,"categorie":"Horaires et durées","niveau":2,"question":"Un cycliste part à 8h00 à 15 km/h. À quelle heure aura-t-il parcouru 60 km ?","options":["11h00","12h00","13h00"],"reponse":"12h00","explication":"60 ÷ 15 = 4 heures. 8h + 4h = 12h00."},
  {"id":165,"categorie":"Problèmes","niveau":2,"question":"La température est de –3°C le matin et monte de 8°C dans la journée. Quelle est la température l'après-midi ?","options":["5°C","11°C","-5°C"],"reponse":"5°C","explication":"–3 + 8 = 5°C."},
