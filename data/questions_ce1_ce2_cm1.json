  {"id":106,"categorie":"Horaires et durées","niveau":1,"question":"L'école finit à 16h30. Il est 15h00. Dans combien de temps fini-t-elle ?","options":["30 min","1h","1h30"],"reponse":"1h30","explication":"De 15h00 à 16h30 = 1 heure 30 minutes."},
