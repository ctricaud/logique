  {"id":103,"categorie":"Suites numériques","niveau":1,"question":"Quelle est la suite : 50, 44, 38, 32, … ?","options":["24","26","28"],"reponse":"26","explication":"On soustrait 6 à chaque fois. 32 – 6 = 26."},
