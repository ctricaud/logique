  {"id":93,"categorie":"Horaires et durées","niveau":3,"question":"Un robinet remplit un réservoir de 180 litres en 3h. Combien de litres par minute remplit-il ?","options":["0,5 L/min","1 L/min","2 L/min"],"reponse":"1 L/min","explication":"3h = 180 min. 180 L ÷ 180 min = 1 L/min."},
  {"id":94,"categorie":"Problèmes","niveau":3,"question":"Une voiture consomme 6 L/100 km. Un plein contient 50 L. Quelle distance peut-elle parcourir ?","options":["600 km","750 km","833 km"],"reponse":"833 km","explication":"50 L ÷ 6 L/100 km × 100 = 833 km environ."},
  {"id":95,"categorie":"Problèmes","niveau":3,"question":"Une remise de 20% est accordée sur un article à 85€. Quel est le prix final ?","options":["63€","68€","72€"],"reponse":"68€","explication":"20% de 85 = 17€. Prix final : 85 – 17 = 68€."},
  {"id":96,"categorie":"Problèmes","niveau":3,"question":"Trois amis partagent également une facture de 97,50€. Combien chacun paie-t-il ?","options":["30€","32,50€","35€"],"reponse":"32,50€","explication":"97,50 ÷ 3 = 32,50€."},
