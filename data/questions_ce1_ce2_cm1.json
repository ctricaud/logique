  {"id":175,"categorie":"Fractions","niveau":3,"question":"Combien font (3/4)² ?","options":["3/8","9/16","6/8"],"reponse":"9/16","explication":"(3/4)² = 3²/4² = 9/16."},
  {"id":176,"categorie":"Calcul mental","niveau":1,"question":"Combien font 7 × 7 ?","options":["42","49","56"],"reponse":"49","explication":"7 × 7 = 49."},
