  {"id":108,"categorie":"Problèmes","niveau":1,"question":"Lola a 8€. Elle achète une glace à 1,50€. Combien lui reste-t-il ?","options":["5,50€","6,50€","7,50€"],"reponse":"6,50€","explication":"8 – 1,50 = 6,50€."},
