  {"id":158,"categorie":"Ordre et classement","niveau":1,"question":"Quel nombre est le plus proche de 50 : 43, 57, 52 ?","options":["43","52","57"],"reponse":"52","explication":"52 est à 2 de 50. 43 est à 7 de 50. 57 est à 7 de 50. Donc 52 est le plus proche."},
